# App
APP_ENV=production
API_TITLE=Encontra.ai Lead Discovery API
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=America/Sao_Paulo
DATABASE_URL=sqlite:////app/data/app.db
EXPORT_DIR=/app/data/exports
SQLITE_JOURNAL_MODE=TRUNCATE
BACKEND_URL=http://backend:8000

# Google
# The app currently uses GOOGLE_API_KEY for Google Places and geocoding.
GOOGLE_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
GOOGLE_GEOCODE_BASE_URL=https://maps.googleapis.com/maps/api/geocode/json

# CNPJ lookup / company search
# Optional. Keep disabled unless a paid/commercial CNPJ provider is configured.
CNPJ_COMPANY_SEARCH_ENABLED=false
CNPJ_COMPANY_SEARCH_PROVIDER=cnpja_commercial
CNPJ_LOOKUP_PROVIDER=cnpja_open
CNPJ_PAID_SEARCH_REPEAT_COOLDOWN_HOURS=24

# CNPJA (optional)
CNPJA_API_KEY=
CNPJA_API_BASE_URL=https://api.cnpja.com
CNPJA_OPEN_API_BASE_URL=https://open.cnpja.com
CNPJA_SEARCH_STRATEGY=CACHE_IF_ERROR
CNPJA_SEARCH_MAX_AGE=45
CNPJA_SEARCH_MAX_STALE=365
CNPJA_COMPANY_SEARCH_LIMIT=10
CNPJA_NAME_VARIANT_LIMIT=4
CNPJA_SEARCH_MODE=balanced
CNPJA_MAX_SEARCH_ATTEMPTS_PER_LEAD=4
CNPJA_MAX_PAID_CALLS_PER_LEAD=4
CNPJA_ENABLE_ZIP_FALLBACK=true
CNPJA_ENABLE_EMAIL_DOMAIN_SEARCH=true
CNPJA_ALLOW_UNMAPPED_PHONE_AREA_FILTER=true
CNPJA_ENABLE_STRICT_ADDRESS_ATTEMPT=false
CNPJA_ENABLE_LEGAL_NAME_ATTEMPT=false
CNPJA_USE_EMAIL_DOMAIN_FILTER=false
CNPJA_USE_CNAE_SEARCH_FILTER=false
CNPJA_RATE_LIMIT_PER_MINUTE=10
CNPJA_BATCH_SIZE=8
CNPJA_RATE_LIMIT_COOLDOWN_SECONDS=65
CNPJA_STOP_BATCH_ON_RATE_LIMIT=true

# Optional / fallback providers
CNPJ_WS_BASE_URL=https://publica.cnpj.ws
CNPJ_WS_PREMIUM_BASE_URL=https://comercial.cnpj.ws
CNPJ_WS_PREMIUM_TOKEN=
CNPJ_WS_PREMIUM_AUTH_MODE=x_api_token

CNPJOTA_BASE_URL=https://api.cnpjota.com.br/api/v1
CNPJOTA_TOKEN=
CNPJOTA_USE_PREVIEW=true

# Sending integrations (keep blank unless used later)
SENDING_ENABLED=false
EMAIL_SENDING_ENABLED=false
WHATSAPP_SENDING_ENABLED=false
DAILY_EMAIL_LIMIT=25
DAILY_WHATSAPP_LIMIT=25
DUPLICATE_SEND_WINDOW_HOURS=72

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

RESEND_API_KEY=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
