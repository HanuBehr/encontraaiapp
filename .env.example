CNPJA_USE_EMAIL_DOMAIN_FILTER=false
CNPJA_USE_CNAE_SEARCH_FILTER=false
CNPJA_RATE_LIMIT_PER_MINUTE=10
CNPJA_BATCH_SIZE=8
CNPJA_RATE_LIMIT_COOLDOWN_SECONDS=65
CNPJA_STOP_BATCH_ON_RATE_LIMIT=true
CNPJ_PAID_SEARCH_REPEAT_COOLDOWN_HOURS=24
