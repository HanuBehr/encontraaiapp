CNPJ_WS_BASE_URL=https://publica.cnpj.ws
CNPJ_COMPANY_SEARCH_PROVIDER=cnpja_commercial
CNPJ_COMPANY_SEARCH_ENABLED=false
CNPJ_WS_PREMIUM_BASE_URL=https://comercial.cnpj.ws
CNPJ_WS_PREMIUM_TOKEN=
CNPJ_WS_PREMIUM_AUTH_MODE=x_api_token
